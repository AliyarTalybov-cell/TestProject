# Supabase (скопируй в .env.local и подставь значения из дашборда Supabase)
# https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Яндекс Погода (GraphQL). Локально подставляется в прокси Vite; на Vercel — в env функции api/weather.
# Без ключа страница погоды возьмёт данные с резервного Open-Meteo (без ключа, меньше полей).
# https://yandex.ru/dev/weather/doc/ru/
VITE_YANDEX_WEATHER_KEY=
